# Supabase (cloud mode — required for web deploy)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Stripe Payment Links (one per plan — create in Stripe Dashboard)
VITE_STRIPE_LINK_STARTER=https://buy.stripe.com/your-starter-link
VITE_STRIPE_LINK_TEAM=https://buy.stripe.com/your-team-link
VITE_STRIPE_LINK_CLUB=https://buy.stripe.com/your-club-link

# Stripe Customer Portal (optional — for subscription management)
VITE_STRIPE_BILLING_PORTAL_URL=https://billing.stripe.com/p/login/your-portal

# Dev only: allow demo subscription activation without Stripe (cloud)
# In production leave false and run supabase/fix-subscription-security.sql
VITE_DEMO_SUBSCRIPTION=false

# Supabase Edge Function secrets (set via supabase secrets set — NOT in Vite)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# SUPABASE_SERVICE_ROLE_KEY=
# STRIPE_PAYMENT_LINK_ID_STARTER=
# STRIPE_PAYMENT_LINK_ID_TEAM=
# STRIPE_PAYMENT_LINK_ID_CLUB=
