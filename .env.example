# Supabase (cloud mode — required for web deploy)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Stripe Payment Links (optional — one per plan)
# Create in Stripe Dashboard → Payment Links, then paste URLs here
VITE_STRIPE_LINK_STARTER=https://buy.stripe.com/your-starter-link
VITE_STRIPE_LINK_TEAM=https://buy.stripe.com/your-team-link
VITE_STRIPE_LINK_CLUB=https://buy.stripe.com/your-club-link
